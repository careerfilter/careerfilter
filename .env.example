# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=.vercel.app,localhost,127.0.0.1,your-domain.com

# Database Configuration (PostgreSQL via Neon/Supabase recommended)
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname

# For local development with SQLite, uncomment:
# DATABASE_URL=sqlite:///db.sqlite3

# Optional: Cloudinary for media file storage
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
