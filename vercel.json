{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "core.settings",
    "PYTHONPATH": "."
  },
  "build": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "core.settings"
    }
  },
  "name": "core",
  "scripts": {
    "prebuild": "python manage.py collectstatic --noinput --clear && python manage.py migrate --noinput"
  }
}
